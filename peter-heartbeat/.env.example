# peter-heartbeat — .env.example
# Copy to .env and fill in real values. Never commit .env.

# Mission Control — all agent Telegram output goes here (group chat)
MISSION_CONTROL_BOT_TOKEN=
MISSION_CONTROL_CHAT_ID=

# STR Clinic dedicated listener bot (create via BotFather — separate from PeterParkerOpenClawBot)
STR_CLINIC_BOT_TOKEN=

# PeterParkerOpenClawBot — primary OpenClaw bot
PETER_TELEGRAM_TOKEN=

# Brandon's direct chat ID (retired for agent use)
BRANDON_CHAT_ID=

# GitHub PAT for PR/repo queries
GITHUB_TOKEN=
